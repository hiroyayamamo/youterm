{
  "name": "youterm",
  "version": "0.16.3",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "description": "Terminal + YouTube in one window. Electron app for macOS that lets you keep coding while YouTube — music videos, lofi streams, anything — plays in the background.",
  "author": "Hiroya Yamamoto <hiroyayamamo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/hiroyayamamo/youterm",
  "repository": {
    "type": "git",
    "url": "https://github.com/hiroyayamamo/youterm.git"
  },
  "bugs": {
    "url": "https://github.com/hiroyayamamo/youterm/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "electron-rebuild -f -w node-pty",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "package": "electron-vite build && electron-builder --mac --dir",
    "package:dmg": "electron-vite build && electron-builder --mac --dmg"
  },
  "build": {
    "appId": "io.github.hiroyayamamo.youterm",
    "productName": "youterm",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/build/Release/*.node"
    ],
    "mac": {
      "target": "dir",
      "identity": null,
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "sign": false
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-store": "^10.1.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
